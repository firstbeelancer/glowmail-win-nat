{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GlowMail AI",
  "version": "0.1.0",
  "identifier": "com.firstbeelancer.glowmail",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "cmd /c set VITE_BACKEND_PROVIDER=native&& npm run dev",
    "beforeBuildCommand": "cmd /c set VITE_BACKEND_PROVIDER=native&& npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GlowMail AI",
        "width": 1480,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
